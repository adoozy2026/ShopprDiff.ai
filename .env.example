# --- Insforge ---
# From your Insforge project settings (https://insforge.dev/dashboard).
# Insforge does NOT expose a direct Postgres connection; all access is via REST.
INSFORGE_PROJECT_URL=https://abwh49kk.us-west.insforge.app
INSFORGE_ANON_KEY=
INSFORGE_SERVICE_ROLE_KEY=

# --- DeepSeek via NVIDIA NIM ---
# https://build.nvidia.com/deepseek-ai/deepseek-v4-pro
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_RESEARCHER=deepseek-ai/deepseek-v4-pro
DEEPSEEK_MODEL_SYNTHESIZER=deepseek-ai/deepseek-v4-pro

# --- Orchestrator runtime ---
# true = serve seeded fixture data instead of hitting DeepSeek + web tools
FIXTURE_MODE=false
ORCHESTRATOR_LOG_LEVEL=info
POLL_INTERVAL_SECONDS=1.5

# --- Web (Next.js) ---
# Browser-visible Insforge config. Set the same values in Vercel project env.
NEXT_PUBLIC_INSFORGE_PROJECT_URL=https://abwh49kk.us-west.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=
